# Gymfile for Ionic Appflow CI builds
# Fixes RevenueCat SPM dependency signing conflict in CI.
#
# - DEVELOPMENT_TEAM: SPM targets need the team to be present
# - CODE_SIGN_STYLE=Manual: Prevents conflict between automatic signing
#   on SPM targets and the manual CODE_SIGN_IDENTITY that Appflow passes

xcargs "DEVELOPMENT_TEAM=Z7DH27LD9D CODE_SIGN_STYLE=Manual"
